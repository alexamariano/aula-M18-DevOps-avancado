pipeline {
    agent any
    tools { nodejs "nodejs"}

    stages {

        stage("Clonar o hub de leitura integrado") {
            steps {
                bat '''
                if exist hub-de-leitura-integrado2 rmdir /s /q hub-de-leitura-integrado2
                git clone https://github.com/EBAC-QE/hub-de-leitura-integrado2.git
                '''
            }
        }

        stage("Instalar dependencias do projeto") {
            steps {
                dir('hub-de-leitura-integrado2') {
                    bat '''
                        call npm install
                        start /B npm start
                    '''
                }
            }
        }

        // ... (os dois primeiros stages do hub-de-leitura-integrado continuam iguais) ...

        stage("Clonar o projeto de teste") {
            steps {
                // 1. Altera o nome da pasta para o nome do seu novo repositório
                bat '''
                    if exist aula-M18-DevOps-avancado rmdir /s /q aula-M18-DevOps-avancado
                    git clone https://github.com/alexamariano/aula-M18-DevOps-avancado.git
                    '''
            }
        }

        stage("Instalar dependencias do projeto de teste") {
            steps {
                // 3. Atualiza o diretório
                dir('aula-M18-DevOps-avancado') {
                    bat 'call npm install'
                }
            }
        }

        stage('Executar os testes automatizados') {
            steps {
                // 4. Atualiza o diretório
                dir('aula-M18-DevOps-avancado') {
                    bat 'call npm test'
                }
            }
        }
    }

    post {
        always {
            bat 'taskkill /F /IM node.exe || exit 0' 
        }
    }
}